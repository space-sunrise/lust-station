# Groups
roadmap-available-now = Already Available
roadmap-in-progress = In Development
roadmap-planned = Planned

# ---- Already Available ----

roadmap-goal-fugitive-name = Fugitive
roadmap-goal-fugitive-desc = An escaped prisoner whose goal is to survive.

roadmap-goal-planet-prison-name = Planet Prison
roadmap-goal-planet-prison-desc = A prison on a planet, functioning as a separate station.

roadmap-goal-cyborg-update-name = Station Borgs
roadmap-goal-cyborg-update-desc = New borgs.

roadmap-goal-collective-mind-name = Collective Mind
roadmap-goal-collective-mind-desc = A system allowing certain creatures to communicate with each other.

roadmap-goal-syndicate-cyborgs-name = Syndicate Borgs
roadmap-goal-syndicate-cyborgs-desc = More advanced and useful syndicate borgs.

roadmap-goal-new-guns-name = Expanded Firearms
roadmap-goal-new-guns-desc = Adding a variety of firearms (what about a flamethrower?).

roadmap-goal-smart-viruse-name = Intelligent Disease
roadmap-goal-smart-viruse-desc = An antagonist whose goal is to infect the station with a disease.

roadmap-goal-cargo-rework-name = Cargo Rework
roadmap-goal-cargo-rework-desc = Removal of the trade outpost and cargo shuttle, implementing buying and selling on the station.

roadmap-goal-new-maps-name = Global Map Rework
roadmap-goal-new-maps-desc = Significant improvements to maps (Delta, Box).

roadmap-goal-fully-translating-name = Full Translation
roadmap-goal-fully-translating-desc = Translation of all items and interfaces to simplify gameplay.

roadmap-goal-mechs-name = Mechs
roadmap-goal-mechs-desc = Piloted mechanoids for working in hard-to-reach places and transporting cargo.

roadmap-goal-assault-ops-name = Assault Squad
roadmap-goal-assault-ops-desc = A squad of mercenaries whose goal is to covertly sabotage the station.

roadmap-goal-flesh-cult-name = Flesh Cult
roadmap-goal-flesh-cult-desc = A flesh cult whose goal is to destroy the station.

roadmap-goal-blood-cult-name = Blood Cult (Nar'Sie)
roadmap-goal-blood-cult-desc = A cult of the god Nar'Sie, whose goal is to summon their patron and destroy the station.

roadmap-goal-vent-crawling-name = Vent Crawling
roadmap-goal-vent-crawling-desc = Ability for small creatures and antagonists to travel through the ventilation system.

roadmap-goal-new-gases-name = New Gases
roadmap-goal-new-gases-desc = New atmospheric gases with unique properties and effects.

roadmap-goal-shooting-name = Shooting Rework
roadmap-goal-shooting-desc = Improvements to shooting mechanics and weapon interaction.

roadmap-goal-surgery-name = Surgery
roadmap-goal-surgery-desc = Expanded surgery mechanics and medical procedures.

roadmap-goal-angels-name = Angel Race
roadmap-goal-angels-desc = A new race of angels with their own unique abilities.

# ---- In Development ----

roadmap-goal-virusology-name = Virology
roadmap-goal-virusology-desc = Reviving virology — you will be able to create and research diseases.

roadmap-goal-ingame-tutorial-name = In-Game Tutorial
roadmap-goal-ingame-tutorial-desc = A tutorial mode for new players inside the game itself.

roadmap-goal-vampires-name = Vampires
roadmap-goal-vampires-desc = An antagonist who feeds on crew blood and can turn victims into servants.

roadmap-goal-pirates-name = Pirates
roadmap-goal-pirates-desc = A squad of space pirates raiding the station for loot.

roadmap-goal-alt-jobs-name = Alternative Jobs
roadmap-goal-alt-jobs-desc = New alternative jobs and roles to diversify gameplay.

# ---- Planned ----

roadmap-goal-economy-name = Economy
roadmap-goal-economy-desc = Adding money and salaries. Mail will provide income, vending machines will charge for food.

roadmap-goal-ipc-name = IPC
roadmap-goal-ipc-desc = A race of sapient machines, currently in development.

roadmap-goal-ert-call-name = ERT Call Console
roadmap-goal-ert-call-desc = A console used to call the Emergency Response Team.

roadmap-goal-blob-name = Blob
roadmap-goal-blob-desc = An antagonist whose goal is to consume and destroy the station.

roadmap-goal-station-goals-rework-name = Station Goals Rework
roadmap-goal-station-goals-rework-desc = Implementation of a CentCom task console instead of a single-goal paper. Completing goals rewards the station with money.

roadmap-goal-borer-name = Brain Worm
roadmap-goal-borer-desc = An antagonist that crawls into the brains of living creatures and takes over their mind.

roadmap-goal-perks-name = New Perks
roadmap-goal-perks-desc = A variety of new character traits to diversify gameplay.

roadmap-goal-arena-name = Ghost Arena
roadmap-goal-arena-desc = An arena where ghosts can spend their time instead of floating around the station waiting for the round to end.

roadmap-goal-limbo-name = Limbo
roadmap-goal-limbo-desc = A separate world for ghosts where there are no rules.
