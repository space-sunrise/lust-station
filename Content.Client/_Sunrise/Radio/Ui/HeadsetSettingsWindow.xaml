<DefaultWindow xmlns="https://spacestation14.io"
                Title="{Loc 'headset-settings-window-title'}"
                MinSize="300 400"
                Resizable="False">
    <BoxContainer Orientation="Vertical" Margin="8">
        <Label Text="{Loc 'headset-settings-channels-label'}" StyleClasses="LabelHeading" Margin="0 0 0 8"/>
        <ScrollContainer VerticalExpand="True">
            <BoxContainer Name="ChannelList" Orientation="Vertical" SeparationOverride="4"/>
        </ScrollContainer>
    </BoxContainer>
</DefaultWindow>
