<widgets:MappingTransparencyWidget
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:widgets="clr-namespace:Content.Client._Sunrise.UserInterface.Systems.Sandbox.Widgets"
    Orientation="Vertical"
    MinSize="190 0">
    <PanelContainer StyleClasses="SunriseMappingWidgetPanel">
        <BoxContainer Orientation="Vertical" SeparationOverride="4" Margin="6 5">
            <Label Name="TitleLabel" Text="{Loc mapping-transparency-widget-title}" />
            <BoxContainer Orientation="Vertical" SeparationOverride="2">
                <Label Name="TransparencyValueLabel" />
                <Slider Name="TransparencySlider" HorizontalExpand="True" />
            </BoxContainer>
        </BoxContainer>
    </PanelContainer>
</widgets:MappingTransparencyWidget>
