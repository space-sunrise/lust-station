<Control xmlns="https://spacestation14.io"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True" SeparationOverride="12">
        <Label Name="EditorHeader" StyleClasses="LabelHeading" Margin="4 4"/>

        <ScrollContainer VerticalExpand="True" HorizontalExpand="True">
            <BoxContainer Orientation="Vertical" SeparationOverride="16" Margin="4">

                <PanelContainer Name="MainEditorPanel" Margin="0 8">
                    <BoxContainer Name="EditorContent" Orientation="Vertical" Margin="8 12" SeparationOverride="12">
                        <!-- Laws Section -->
                        <BoxContainer Orientation="Vertical" SeparationOverride="8">
                            <Label Text="{Loc 'sunrise-records-select-laws'}" StyleClasses="LabelHeading"/>
                            <PanelContainer StyleClasses="LowDivider" MinHeight="1"/>
                            <BoxContainer Name="LawsContainer" Orientation="Vertical" SeparationOverride="12"/>
                        </BoxContainer>

                        <!-- Circumstances Section -->
                        <BoxContainer Orientation="Vertical" SeparationOverride="8">
                            <Label Text="{Loc 'sunrise-records-circumstances-header'}" StyleClasses="LabelHeading"/>
                            <PanelContainer StyleClasses="LowDivider" MinHeight="1"/>
                            <BoxContainer Name="MitigatingContainer" Orientation="Vertical" SeparationOverride="8"/>
                            <BoxContainer Name="AggravatingContainer" Orientation="Vertical" SeparationOverride="8"/>
                        </BoxContainer>
                    </BoxContainer>
                </PanelContainer>

                <!-- Simplified Read-Only View -->
                <PanelContainer Name="ReadOnlyContent" Margin="0 4" Visible="False">
                    <BoxContainer Orientation="Vertical" Margin="8 12" SeparationOverride="12">
                        <BoxContainer Name="ReadOnlyList" Orientation="Vertical" SeparationOverride="4"/>
                    </BoxContainer>
                </PanelContainer>
            </BoxContainer>
        </ScrollContainer>

        <PanelContainer StyleClasses="LowDivider" MinHeight="2"/>

        <!-- Fixed Bottom Block -->
        <BoxContainer Orientation="Vertical" SeparationOverride="8" Margin="4">
            <!-- Summary Card -->
            <PanelContainer Name="NotesPanel" Margin="0 4">
                <BoxContainer Orientation="Vertical" Margin="12" SeparationOverride="8">
                    <Label Text="{Loc 'sunrise-records-notes'}" StyleClasses="LabelHeading"/>
                    <PanelContainer StyleClasses="LowDivider" MinHeight="1"/>
                    <TextEdit Name="NotesInput" HorizontalExpand="True" MinHeight="80" VerticalExpand="True"/>

                    <Label Name="SentenceLabel" StyleClasses="LabelBig" HorizontalAlignment="Center" Margin="0 8 0 0"/>
                </BoxContainer>
            </PanelContainer>

            <!-- Actions -->
            <BoxContainer Orientation="Horizontal" HorizontalAlignment="Center" SeparationOverride="12" Margin="0 4">
                <Button Name="BackButton" Text="{Loc 'sunrise-records-back-to-cases'}" StyleClasses="ButtonSquare"/>
                <Button Name="FinalizeButton" Text="{Loc 'sunrise-records-finalize-case'}" StyleClasses="ButtonSquare"/>
            </BoxContainer>
        </BoxContainer>
    </BoxContainer>
</Control>
